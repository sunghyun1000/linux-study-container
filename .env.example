# Linux 실습실 환경 설정
# cp .env.example .env 후 편집

# 웹 UI 도메인 (Caddy가 자동으로 TLS 발급)
DOMAIN="linux.example.com"

# 호스트 외부 NIC 이름 (ip a 로 확인)
HOST_IFACE="enp0s6"

# 웹앱을 실행할 서버 사용자
INSTALL_USER="ubuntu"

# 컨테이너 수 (1~100)
CONTAINER_COUNT="10"

# 컨테이너 내부 IP 시작 옥텟 (10.10.0.{OFFSET} ~ 10.10.0.{OFFSET+COUNT-1})
# 예: OFFSET=10, COUNT=10 → 10.10.0.10 ~ 10.10.0.19
CONTAINER_IP_OFFSET="10"

# LXD 브리지 IP (기본값 권장)
LXD_BRIDGE_IP="10.10.0.1"
LXD_BRIDGE_SUBNET="10.10.0.0/24"

# Secondary Private IP 목록 (클라우드 콘솔에서 할당한 내부 IP)
# CONTAINER_COUNT와 개수가 반드시 일치해야 합니다
SECONDARY_IPS=(
  "10.0.10.100"
  "10.0.10.101"
  "10.0.10.102"
  "10.0.10.103"
  "10.0.10.104"
  "10.0.10.105"
  "10.0.10.106"
  "10.0.10.107"
  "10.0.10.108"
  "10.0.10.109"
)
